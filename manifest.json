{
  "manifest_version": 3,
  "name": "ApplyIQ",
  "version": "1.0.0",
  "description": "ATS score checker, resume optimizer, and auto-fill powered by Claude AI.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://latex.ytotech.com/*"
  ],
  "icons": {
    "16": "icons/applyiq_icon.png",
    "48": "icons/applyiq_icon.png",
    "128": "icons/applyiq_icon.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/applyiq_icon.png",
      "48": "icons/applyiq_icon.png",
      "128": "icons/applyiq_icon.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["injector.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}